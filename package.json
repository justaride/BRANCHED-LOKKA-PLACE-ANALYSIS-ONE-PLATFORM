{
  "name": "lokka-gardeierforening-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "verify": "node scripts/verify-project.js",
    "research:kultur:enrich": "node scripts/enrich-kultur-research.js",
    "research:kultur:validate": "node scripts/validate-kultur-research.js",
    "research:biblioteket:validate": "node scripts/validate-biblioteket-research.js",
    "research:biblioteket:report": "node scripts/report-biblioteket-research.js",
    "research:biblioteket:audit": "node scripts/audit-biblioteket-quality.js",
    "research:biblioteket:audit:strict": "node scripts/audit-biblioteket-quality.js --fail-on-high",
    "research:biblioteket:content-audit": "node scripts/audit-biblioteket-content-quality.js",
    "research:biblioteket:queue": "node scripts/build-biblioteket-research-queue.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:nedre-lokka-svarut": "node scripts/build-nedre-lokka-svarut.js",
    "verify:nedre-lokka-svarut": "npm run build:nedre-lokka-svarut && npm test -- src/lib/utils/__tests__/nedre-lokka-svarut-data.test.ts",
    "audit:data": "node scripts/data-audit/index.js --verbose",
    "audit:data:critical": "node scripts/data-audit/index.js --critical",
    "prebuild": "node scripts/clean-build-cache.mjs && npm run verify && npm run type-check",
    "migrate": "tsx src/db/migrate.ts",
    "seed:arshjul": "tsx src/db/seed-arshjul.ts"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.23.24",
    "jose": "^6.1.3",
    "leaflet": "^1.9.4",
    "next": "^16.2.6",
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "resend": "^4.5.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.30",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jest": "^29",
    "tailwindcss": "^4",
    "ts-jest": "^29",
    "tsx": "^4.22.4",
    "typescript": "5.9.3"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
